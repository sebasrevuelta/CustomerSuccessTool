# SQLAlchemy database URL (required by app.py and nurture.py)
DATABASE_URL=

# Google Sheet ID (from the sheet URL: .../d/SHEET_ID/edit)
GOOGLE_SHEET_ID=
# Path to service account JSON key file (default: credentials.json in project root)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Customer_Success sheet config
GOOGLE_SHEET_TAB=
GOOGLE_SHEET_HEADER_ROW=

# Feature Request sheet config
GOOGLE_FEATURE_REQUEST_TAB=
GOOGLE_FEATURE_REQUEST_HEADER_ROW=

# If true, load demo SQL data on startup instead of Google Sheet sync.
LOAD_DEMO_DATA=False

# OIDC login configuration (set OIDC_ENABLED=True to require login)
OIDC_ENABLED=False
# OIDC_DISCOVERY_URL=https://your-idp/.well-known/openid-configuration
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://127.0.0.1:5001/auth/callback
# OIDC_SCOPE=openid profile email

# Optional: enable Flask debug mode
# FLASK_DEBUG=false
