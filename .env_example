# Internal PostgreSQL credentials are fetched from AWS Secrets Manager:
#   prod/customer_success_health_score_tool/internal_database
# Optional overrides:
# INTERNAL_DATABASE_HOST=127.0.0.1
# INTERNAL_DATABASE_PORT=5432
# INTERNAL_DATABASE_NAME=customer_success

# GOOGLE_SHEET_ID is always fetched from AWS Secrets Manager:
#   prod/customer_health_score_tool/google_sheet_id
# Google service-account credentials JSON is always fetched from:
#   prod/customer_health_score_tool/google_credentials
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=
# Optional service-specific overrides:
# AWS_SECRETS_MANAGER_ACCESS_KEY_ID=
# AWS_SECRETS_MANAGER_SECRET_ACCESS_KEY=
# AWS_SECRETS_MANAGER_SESSION_TOKEN=
# AWS_SECRETS_MANAGER_PROFILE=
# AWS_SECRETS_MANAGER_ENDPOINT_URL=
# GOOGLE_CREDENTIALS_PATH is no longer used.

# Customer_Success sheet config
GOOGLE_SHEET_TAB=
GOOGLE_SHEET_HEADER_ROW=

# Feature Request sheet config
GOOGLE_FEATURE_REQUEST_TAB=
GOOGLE_FEATURE_REQUEST_HEADER_ROW=

# If true, load demo SQL data on startup instead of Google Sheet sync.
LOAD_DEMO_DATA=True

# Read source when LOAD_DEMO_DATA=False:
# - True: read from internal PostgreSQL (DATABASE_URL)
# - False: read from production database (METABASE_DATABASE_URL)
READ_FROM_INTERNAL_DATABASE=True
METABASE_DATABASE_URL=

# OIDC login configuration (set OIDC_ENABLED=True to require login)
OIDC_ENABLED=False
# OIDC_DISCOVERY_URL=https://your-idp/.well-known/openid-configuration
# OIDC_CLIENT_ID is always fetched from AWS Secrets Manager:
#   prod/customer_health_score_tool/oidc
# OIDC_CLIENT_SECRET is always fetched from AWS Secrets Manager:
#   prod/customer_health_score_tool/oidc
# OIDC_REDIRECT_URI=http://127.0.0.1:5001/auth/callback
# OIDC_SCOPE=openid profile email
# OIDC_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:5001/login
# OIDC_USE_POST_LOGOUT_REDIRECT_URI=False

# Session cookie and trusted proxy hardening (recommended in production)
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_SAMESITE=Lax
# SESSION_COOKIE_NAME=customer_success_session
# TRUST_PROXY_HEADERS=True
# PROXY_FIX_X_FOR=1
# PROXY_FIX_X_PROTO=1
# PROXY_FIX_X_HOST=1
# PROXY_FIX_X_PORT=1

# Optional: enable Flask debug mode
# FLASK_DEBUG=false

# Flask session signing key (required for stable sessions across workers)
FLASK_SECRET_KEY=replace-with-a-long-random-string
